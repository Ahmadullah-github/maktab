              "raw": "{\n  \"teachers\": [\n    {\n      \"id\": 1,\n      \"name\": \"احمد محمدی\",\n      \"subjects\": [1, 2],\n      \"maxPeriodsPerDay\": 6,\n      \"availability\": {\n        \"saturday\": [1, 2, 3, 4, 5, 6],\n        \"sunday\": [1, 2, 3, 4, 5, 6],\n        \"monday\": [1, 2, 3, 4, 5, 6],\n        \"tuesday\": [1, 2, 3, 4, 5, 6],\n        \"wednesday\": [1, 2, 3, 4, 5, 6]\n      }\n    }\n  ],\n  \"subjects\": [\n    {\n      \"id\": 1,\n      \"name\": \"ریاضی\",\n      \"periodsPerWeek\": 5,\n      \"requiresLab\": false\n    },\n    {\n      \"id\": 2,\n      \"name\": \"فیزیک\",\n      \"periodsPerWeek\": 3,\n      \"requiresLab\": true\n    }\n  ],\n  \"classes\": [\n    {\n      \"id\": 1,\n      \"name\": \"کلاس هفتم الف\",\n      \"grade\": \"7\",\n      \"shift\": \"morning\",\n      \"subjects\": [1, 2]\n    }\n  ],\n  \"rooms\": [\n    {\n      \"id\": 1,\n      \"name\": \"اتاق ۱۰۱\",\n      \"type\": \"classroom\",\n      \"capacity\": 40\n    },\n    {\n      \"id\": 2,\n      \"name\": \"آزمایشگاه فیزیک\",\n      \"type\": \"lab\",\n      \"capacity\": 30\n    }\n  ],\n  \"config\": {\n    \"daysPerWeek\": 5,\n    \"periodsPerDay\": [6, 6, 6, 6, 6],\n    \"strategy\": \"balanced\"\n  }\n}"
