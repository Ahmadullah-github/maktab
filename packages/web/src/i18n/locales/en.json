    "avoidTeacherGaps": {
      "label": "Avoid Teacher Gaps",
      "description": "Minimize free periods between teacher's classes",
      "tooltip": "When enabled, the system tries to schedule teacher's classes consecutively so they have fewer idle periods during the day. This allows teachers to finish their work earlier."
    },

    "balanceTeacherLoad": {
      "label": "Balance Teacher Load",
      "description": "Distribute teaching hours evenly across days",
      "tooltip": "The system tries to distribute each teacher's teaching hours equally across the week. For example, if a teacher has 12 hours per week, they would have 2 hours per day instead of 6 hours on one day."
    },

    "respectTeacherTimePreference": {
      "label": "Respect Teacher Time Preference",
      "description": "Consider teacher's morning/afternoon preferences",
      "tooltip": "If a teacher has specified a morning or afternoon preference, the system will try to schedule their classes during that time slot. This helps improve teacher satisfaction."
    },

    "respectTeacherRoomPreference": {
      "label": "Respect Teacher Room Preference",
      "description": "Consider teacher's preferred rooms",
      "tooltip": "If a teacher has specified preferred rooms, the system will try to schedule their classes in those rooms. Useful for teachers who need specific equipment."
    },

    "avoidClassGaps": {
      "label": "Avoid Class Gaps",
      "description": "Minimize free periods for students",
      "tooltip": "The system tries to schedule classes without gaps between periods. This reduces student waiting time and makes the school day more compact."
    },

    "distributeDifficultSubjects": {
      "label": "Distribute Difficult Subjects",
      "description": "Spread hard subjects across the week",
      "tooltip": "Difficult subjects (like Math and Physics) are distributed across different days of the week so students don't have multiple hard subjects on the same day. This helps improve learning outcomes."
    },

    "preferMorningForDifficult": {
      "label": "Morning for Difficult Subjects",
      "description": "Schedule hard subjects in early periods",
      "tooltip": "Difficult subjects are scheduled in the early periods of the day when student concentration is highest. Easier subjects are placed in later periods."
    },

    "subjectSpread": {
      "label": "Subject Spread Across Week",
      "description": "Distribute subject hours across different days",
      "tooltip": "If a subject has 4 hours per week, the system tries to spread them across 4 different days instead of 2 days with 2 hours each. This helps reinforce learning."
    },

    "allowConsecutivePeriods": {
      "label": "Allow Consecutive Periods",
      "description": "Allow same subject in back-to-back periods",
      "tooltip": "When enabled, a subject can be scheduled in two consecutive periods (e.g., Math in periods 1 and 2). Useful for subjects that need more time like lab sessions."
    },

    "minimizeRoomChanges": {
      "label": "Minimize Room Changes",
      "description": "Keep classes in the same room when possible",
      "tooltip": "The system tries to keep each class in a fixed room and minimize room changes. This reduces transition time and improves order."
    },

