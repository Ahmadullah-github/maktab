{
  "enabled": true,
  "name": "API Postman Testing",
  "description": "Monitors API source code changes and automatically runs Postman collection tests to validate functionality",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "packages/api/**/*.ts",
      "packages/api/**/*.js",
      "packages/api/package.json",
      "packages/api/schema.ts",
      "packages/api/src/**/*.ts",
      "packages/solver/**/*.py",
      "packages/solver/requirements.txt",
      "packages/solver/solver_enhanced.py"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "API source code or configuration has been modified. Please retrieve the contents of the .postman.json file. If the file does not exist or is empty, create a Postman collection for the Maktab API. If it exists, get the collection ID and run the collection, showing me the results and propose fixes for any errors found."
  }
}
